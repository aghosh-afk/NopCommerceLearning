@model Nop.Plugin.Misc.CustomerReminder.Models.CustomerReminderSearchModel

@using Nop.Web.Framework.Models.DataTables
@using Nop.Web.Framework

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Plugins.Misc.CustomerReminder.Admin.List.Title").Text;
}

<h1>@ViewBag.PageTitle</h1>

<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

<div class="content-header clearfix">
    <div class="float-right">
        <a href="@Url.Action("Create", "CustomerReminder", new { area = "Admin" })"
           class="btn btn-success">
            <i class="fas fa-plus"></i>
            @T("Plugins.Misc.CustomerReminder.Admin.Button.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <!-- SEARCH FILTERS -->
        <div class="card card-default card-search">
            <div class="card-body">
                <div class="row">

                    <!-- Customer Dropdown -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="CustomerId"></label>
                            <input id="CustomerId" style="width:100%;" />
                        </div>
                    </div>

                    <!-- IsSent -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="IsSent"></label>
                            <select asp-for="IsSent" class="form-control">
                                <option value="">All</option>
                                <option value="true">Sent</option>
                                <option value="false">Not Sent</option>
                            </select>
                        </div>
                    </div>

                    <!-- From Date -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="FromDate"></label>
                            <input asp-for="FromDate" class="form-control" />
                        </div>
                    </div>

                    <!-- To Date -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="ToDate"></label>
                            <input asp-for="ToDate" class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="row mt-2">
                    <div class="col-md-12 text-center">
                        <button type="button"
                                id="search-reminders"
                                class="btn btn-primary">
                            <i class="fas fa-search"></i>
                            @T("Plugins.Misc.CustomerReminder.Admin.Button.Search")
                        </button>
                        <button id="resetBtn" class="btn btn-secondary">
                            <i class="fas fa-undo"></i> @T("Plugins.Misc.CustomerReminder.Admin.Button.ResetFilter")
                        </button>
                    </div>
                </div>
                
            </div>
        </div>

        <!-- GRID -->
        <div class="card card-default">
            <div class="card-body">

            @await Html.PartialAsync("Table", new DataTablesModel
            {
                Name = "customerReminderGrid",
                UrlRead = new DataUrl("List", "CustomerReminder", new RouteValueDictionary { [nameof(Model)] = Model }),
                Length = Model.PageSize,
                LengthMenu = Model.AvailablePageSizes,

                Filters = new List<FilterParameter>
                {
                    new FilterParameter(nameof(Model.CustomerId)),
                    new FilterParameter(nameof(Model.IsSent)),
                    new FilterParameter(nameof(Model.FromDate)),
                    new FilterParameter(nameof(Model.ToDate))
                },

                ColumnCollection = new List<ColumnProperty>
                {
                    new ColumnProperty(nameof(CustomerReminderModel.Id))
                    {
                        Title = "Id",
                        Width = "60"
                    },

                    new ColumnProperty(nameof(CustomerReminderModel.CustomerName))
                    {
                        Title = "Customer"
                    },

                    new ColumnProperty(nameof(CustomerReminderModel.ReminderTitle))
                    {
                        Title = "Title"
                    },

                    new ColumnProperty(nameof(CustomerReminderModel.ReminderDate))
                    {
                        Title = "Reminder Date",
                        Render = new RenderCustom("renderReminderDate")
                    },

                    new ColumnProperty(nameof(CustomerReminderModel.IsSent))
                    {
                        Title = "Sent",
                        Width = "100",
                        ClassName = "text-center",
                        Render = new RenderCustom("renderSentStatus")
                    },

                    new ColumnProperty(nameof(CustomerReminderModel.Id))
                    {
                        Title = "Actions",
                        Width = "150",
                        ClassName = "text-center",
                        Render = new RenderCustom("renderActions"),
                        Sortable = false
                    }
                }
            })

        </div>
            </div>
        </div>

    </div>
</section>

@section Scripts{

<script>
$(document).ready(function () {

    var dataTableName = "customerReminderGrid";

    // -----------------------------------
    // KENDO CUSTOMER DROPDOWN
    // -----------------------------------
    $("#CustomerId").kendoDropDownList({
        optionLabel: '@T("Plugins.Misc.CustomerReminder.Admin.SelectCustomer")',
        dataTextField: "FullName",
        dataValueField: "Id",
        filter: "contains",
        minLength: 0,
        autoBind: true,
        dataSource: {
            serverFiltering: true,
            serverPaging: true,
            pageSize: 10,
            transport: {
                read: {
                    url: '@Url.Action("CustomerList","CustomerReminder", new { area = "Admin" })',
                    type: "POST",
                    dataType: "json"
                },
                parameterMap: function (data) {

                    var searchValue = "";

                    if (data.filter && data.filter.filters.length > 0) {
                        searchValue = data.filter.filters[0].value;
                    }

                    return {
                        page: data.page || 1,
                        pageSize: data.pageSize || 10,
                        search: searchValue,
                        __RequestVerificationToken:
                            $('input[name="__RequestVerificationToken"]').val()
                    };
                }
            },
            schema: {
                data: "Data",
                total: "Total"
            }
        }
    });

    // -----------------------------------
    // DATATABLE INITIALIZATION
    // -----------------------------------
    var table = $("#" + dataTableName).DataTable({

        ajax: {
            url: '@Url.Action("List","CustomerReminder", new { area = "Admin" })',
            type: "POST",
            data: function (d) {

                d.CustomerId = $("#CustomerId").val() || null;
                d.IsSent = $("#IsSent").val() || null;
                d.FromDate = $("#FromDate").val() || null;
                d.ToDate = $("#ToDate").val() || null;

                // Send sorting info
                if (d.order && d.order.length > 0) {
                    d.sortColumn = d.order[0].column;
                    d.sortDirection = d.order[0].dir;
                }

                d.__RequestVerificationToken =
                    $('input[name="__RequestVerificationToken"]').val();

                return d;
            }
        },

        serverSide: true,
        processing: true,

        order: [[0, "desc"]],

        pageLength: @Model.PageSize,
        lengthMenu: @Html.Raw(Json.Serialize(Model.AvailablePageSizes)),

        columns: [

            { data: "Id", title: "Id", width: "60px", orderable: true },

            { data: "CustomerName", title: "Customer", orderable: true },

            { data: "ReminderTitle", title: "Title", orderable: true },

            {
                data: "ReminderDate",
                title: "Reminder Date",
                orderable: true,
                render: function (data) {
                    if (!data) return "";
                    return moment(data).format("DD-MM-YYYY HH:mm");
                }
            },

            {
                data: "IsSent",
                title: "Sent",
                width: "100px",
                className: "text-center",
                orderable: true,
                render: function (data) {
                    return data
                        ? '<span class="badge badge-success">Yes</span>'
                        : '<span class="badge badge-danger">No</span>';
                }
            },

            {
                data: "Id",
                title: "Actions",
                width: "150px",
                orderable: false,
                className: "text-center",
                render: function (data) {

                    var editUrl =
                        '@Url.Action("Edit","CustomerReminder", new { area = "Admin" })/' + data;

                    return `
                        <a href="${editUrl}" class="btn btn-sm btn-primary">
                            <i class="fas fa-edit"></i>
                        </a>

                        <button class="btn btn-sm btn-danger delete-reminder"
                                data-id="${data}">
                            <i class="fas fa-trash"></i>
                        </button>
                    `;
                }
            }
        ]
    });

    // -----------------------------------
    // SEARCH BUTTON
    // -----------------------------------
    $("#search-reminders").click(function () {
        table.ajax.reload();
    });

    // -----------------------------------
    // RESET FILTER BUTTON
    // -----------------------------------
    $("#resetBtn").click(function (e) {

        e.preventDefault();

        var dropdown = $("#CustomerId").data("kendoDropDownList");
        if (dropdown) {
            dropdown.value("");
        }

        $("#IsSent").val("");
        $("#FromDate").val("");
        $("#ToDate").val("");

        table.ajax.reload();
    });

    // -----------------------------------
    // DELETE REMINDER
    // -----------------------------------
    $(document).on("click", ".delete-reminder", function () {

        if (!confirm("Are you sure you want to delete this reminder?"))
            return;

        var id = $(this).data("id");

        $.ajax({
            url: '@Url.Action("Delete","CustomerReminder", new { area = "Admin" })',
            type: "POST",
            data: {
                id: id,
                __RequestVerificationToken:
                    $('input[name="__RequestVerificationToken"]').val()
            },
            success: function () {
                table.ajax.reload();
            },
            error: function () {
                alert("Error deleting reminder.");
            }
        });

    });

});
</script>

}
