@model Nop.Plugin.Misc.CustomerReminder.Models.CustomerReminderModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Plugins.Misc.CustomerReminder.Admin.Create.Title").Text;
}
<h1>@ViewBag.PageTitle</h1>

<form asp-action="Create"
      asp-controller="CustomerReminder"
      asp-area="Admin"
      method="post"
      id="customerReminderForm">

    @Html.AntiForgeryToken()

    <div class="content-header clearfix">
        <div class="float-right">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i>
                @T("Plugins.Misc.CustomerReminder.Admin.Button.Save")
            </button>
            <a asp-action="List"
               asp-controller="CustomerReminder"
               asp-area="Admin"
               class="btn btn-secondary">
                @T("Plugins.Misc.CustomerReminder.Admin.Button.Cancel")
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card card-default">
                <div class="card-body">

                    <!-- Customer -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CustomerId" />
                        </div>
                        <div class="col-md-9">

                            <input asp-for="CustomerId" type="hidden" />
                            <input id="CustomerIdDropdown" style="width:100%;" />

                            <span asp-validation-for="CustomerId"></span>
                        </div>
                    </div>

                    <!-- Reminder Title -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderTitle" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="ReminderTitle" />
                            <span asp-validation-for="ReminderTitle"></span>
                        </div>
                    </div>

                    <!-- Reminder Message -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderMessage" />
                        </div>
                        <div class="col-md-9">
                            <nop-textarea asp-for="ReminderMessage" />
                            <span asp-validation-for="ReminderMessage"></span>
                        </div>
                    </div>

                    <!-- Reminder Date -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderDate" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="ReminderDate" />
                            <span asp-validation-for="ReminderDate"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>

@section Scripts {
<script>
    $(document).ready(function () {

    var hiddenField = $("#CustomerId");

    $("#CustomerIdDropdown").kendoDropDownList({
        optionLabel: '@T("Plugins.Misc.CustomerReminder.Admin.SelectCustomer")',
        dataTextField: "FullName",
        dataValueField: "Id",
        filter: "contains",
        autoBind: true,
        minLength: 2,
        value: hiddenField.val(),   // 🔥 IMPORTANT
        change: function () {
            hiddenField.val(this.value());
        },
        dataSource: {
            serverFiltering: true,
            serverPaging: true,
            pageSize: 10,
            transport: {
                read: {
                    url: '@Url.Action("CustomerList", "CustomerReminder", new { area = "Admin" })',
                    type: "POST",
                    dataType: "json"
                },
                parameterMap: function (data) {

                    var searchValue = "";
                    if (data.filter && data.filter.filters.length > 0) {
                        searchValue = data.filter.filters[0].value;
                    }

                    return {
                        page: data.page || 1,
                        pageSize: data.pageSize || 10,
                        search: searchValue,
                        __RequestVerificationToken:
                            $('input[name="__RequestVerificationToken"]').val()
                    };
                }
            },
            schema: {
                data: "Data",
                total: "Total"
            }
        }
    });

});
</script>
}