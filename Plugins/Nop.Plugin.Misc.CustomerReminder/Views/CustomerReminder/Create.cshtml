@model Nop.Plugin.Misc.CustomerReminder.Data.CustomerReminderRecord

@using Nop.Web.Framework.Models.DataTables
@using Nop.Web.Framework.Models
@using Nop.Web.Framework
@using Nop.Plugin.Misc.CustomerReminder.Models

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "Create Customer Reminder";
}

<div class="content">
    <div class="container-fluid">

        <form asp-action="Create"
              asp-controller="CustomerReminder"
              asp-area="Admin"
              method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="card">
                <div class="card-body">

                    <!-- Customer -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="CustomerId" class="control-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="CustomerId" id="CustomerId" style="width:100%;" />
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Title -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="ReminderTitle" class="control-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="ReminderTitle" class="form-control" />
                            <span asp-validation-for="ReminderTitle" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Message -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="ReminderMessage" class="control-label"></label>
                        </div>
                        <div class="col-md-9">
                            <textarea asp-for="ReminderMessage" class="form-control"></textarea>
                            <span asp-validation-for="ReminderMessage" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Reminder Date -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <label asp-for="ReminderDate" class="control-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="ReminderDate"
                                   type="datetime-local"
                                   class="form-control" />
                            <span asp-validation-for="ReminderDate" class="text-danger"></span>
                        </div>
                    </div>

                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save
                    </button>

                    <a asp-action="List"
                       asp-controller="CustomerReminder"
                       asp-area="Admin"
                       class="btn btn-secondary">
                        Cancel
                    </a>
                </div>
            </div>

        </form>
    </div>
</div>

<!-- Kendo ComboBox -->
<script asp-location="Footer">
    $(document).ready(function () {

        $("#CustomerId").kendoComboBox({
            dataTextField: "name",
            dataValueField: "id",
            filter: "contains",
            minLength: 2,
            autoBind: false,
            valuePrimitive: true,
            placeholder: "Search customer...",
            dataSource: {
                transport: {
                    read: {
                        url: "@Url.Action("CustomerList", "CustomerReminder", new { area = "Admin" })",
                        type: "POST",
                        data: function () {
                            return {
                                search: $("#CustomerId").data("kendoComboBox").text(),
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            };
                        }
                    }
                },
                schema: {
                    data: "Data",
                    total: "Total"
                },
                serverFiltering: true,
                serverPaging: true,
                pageSize: 20
            }
        });

    });
</script>
