@model Nop.Plugin.Misc.CustomerReminder.Models.CustomerReminderModel

@{
        Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.PageTitle = "Create Customer Reminder";
}

<form asp-action="Create"
      asp-controller="CustomerReminder"
      asp-area="Admin"
      method="post"
      id="customerReminderForm">

    @Html.AntiForgeryToken()

    <div class="content-header clearfix">
        <h1 class="float-left">
            Create Customer Reminder
        </h1>
        <div class="float-right">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Save
            </button>
            <a asp-action="List"
               asp-controller="CustomerReminder"
               asp-area="Admin"
               class="btn btn-secondary">
                Cancel
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card card-default">
                <div class="card-body">

                    <!-- Customer -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CustomerId" />
                        </div>
                        <div class="col-md-9">
                            <input asp-for="CustomerId"
                                   id="CustomerId"
                                   style="width:100%;" />
                            <span asp-validation-for="CustomerId"></span>
                        </div>
                    </div>

                    <!-- Reminder Title -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderTitle" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="ReminderTitle" />
                            <span asp-validation-for="ReminderTitle"></span>
                        </div>
                    </div>

                    <!-- Reminder Message -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderMessage" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="ReminderMessage" />
                            <span asp-validation-for="ReminderMessage"></span>
                        </div>
                    </div>

                    <!-- Reminder Date -->
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="ReminderDate" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="ReminderDate" />
                            <span asp-validation-for="ReminderDate"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Customer dropdown
            $("#CustomerId").kendoDropDownList({
                optionLabel: "Select Customer...",
                dataTextField: "FullName",
                dataValueField: "Id",
                filter: "contains",
                autoBind: true,
                minLength: 2,

                dataSource: {
                    serverFiltering: true,
                    serverPaging: true,
                    pageSize: 10,
                    transport: {
                        read: {
                            url: '@Url.Action("CustomerList", "CustomerReminder", new { area = "Admin" })',
                            type: "POST",
                            dataType: "json"
                        },
                        parameterMap: function (data) {

                            var searchValue = "";
                            if (data.filter && data.filter.filters.length > 0) {
                                searchValue = data.filter.filters[0].value;
                            }

                            return {
                                page: data.page || 1,
                                pageSize: data.pageSize || 10,
                                search: searchValue,
                                __RequestVerificationToken:
                                    $('input[name="__RequestVerificationToken"]').val()
                            };
                        }
                    },
                    schema: {
                        data: "Data",
                        total: "Total"
                    }
                }
            });

        });
    </script>
}